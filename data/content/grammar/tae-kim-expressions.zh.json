[
  {
    "id": "grammar:tae-kim:passive-form",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:passive-form",
    "slug": "passive-form",
    "category": "voice",
    "list_name": "voice-and-politeness",
    "expression": "受身形（～れる／～られる）",
    "connection": "一段动词去る + られる；五段动词末音变为あ段（う→わ）+ れる；する→される，来る→こられる；施事者常用に标记",
    "explanation_zh": "把承受动作的人或事物放在主语位置；日语也常用受身形表达某事给自己带来的困扰或影响。",
    "source_url": "https://guidetojapanese.org/learn/grammar/causepass",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 61,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "私は電車で隣の人に足を踏まれました。",
        "zh": "我在电车里被旁边的人踩了脚。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "一段动词的「～られる」也可能是可能形；受身句关注承受者并常出现「施事者 + に」，不要只看词尾就判断为“能够”。"
    ],
    "related_entries": [
      "grammar:tae-kim:causative-form",
      "grammar:tae-kim:potential-form"
    ]
  },
  {
    "id": "grammar:tae-kim:causative-form",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:causative-form",
    "slug": "causative-form",
    "category": "voice",
    "list_name": "voice-and-politeness",
    "expression": "使役形（～せる／～させる）",
    "connection": "一段动词去る + させる；五段动词末音变为あ段（う→わ）+ せる；する→させる，来る→こさせる",
    "explanation_zh": "表示让、允许或迫使某人做某事；究竟是许可还是强制，要由关系和语境判断。",
    "source_url": "https://guidetojapanese.org/learn/grammar/causepass",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 62,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "部長は新人に資料を作らせました。",
        "zh": "部长让新人制作了资料。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "使役形的主语是促成动作的人，实际行动者常用「に／を」标记；不要把「新人に作らせた」误当成新人受到动作的普通受身句。"
    ],
    "related_entries": [
      "grammar:tae-kim:passive-form",
      "grammar:tae-kim:causative-passive"
    ]
  },
  {
    "id": "grammar:tae-kim:causative-passive",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:causative-passive",
    "slug": "causative-passive",
    "category": "voice",
    "list_name": "voice-and-politeness",
    "expression": "使役受身形（～させられる）",
    "connection": "先把动词变为使役形，再把所得的一段动词变为受身形：食べる→食べさせる→食べさせられる",
    "explanation_zh": "表示主语被别人要求或迫使做某事，重点同时落在“使其行动”和“本人承受”上。",
    "source_url": "https://guidetojapanese.org/learn/grammar/causepass",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 63,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "私は先生に作文を書き直させられました。",
        "zh": "我被老师要求重写作文。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "变形顺序只能是“使役后受身”，不能先做受身再加使役；「書かれた」只是被写／受到书写动作，不等于“被迫写”。"
    ],
    "related_entries": [
      "grammar:tae-kim:causative-form",
      "grammar:tae-kim:passive-form"
    ]
  },
  {
    "id": "grammar:tae-kim:honorific-verbs",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:honorific-verbs",
    "slug": "honorific-verbs",
    "category": "politeness",
    "list_name": "voice-and-politeness",
    "expression": "尊敬语动词",
    "connection": "特殊尊敬动词（いらっしゃる、召し上がる等）；或 お／ご + 动词连用形 + になる",
    "explanation_zh": "抬高听者、顾客或话题中应受尊敬者的动作；特殊动词优先于一般构式。",
    "source_url": "https://guidetojapanese.org/learn/grammar/honorific",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 64,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "社長はもうお帰りになりました。",
        "zh": "社长已经回去了。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "尊敬语用于对方或应受尊敬者的动作，通常不用来抬高自己；说自己的动作时应考虑谦让语。"
    ],
    "related_entries": [
      "grammar:tae-kim:humble-verbs",
      "grammar:tae-kim:polite-masu"
    ]
  },
  {
    "id": "grammar:tae-kim:humble-verbs",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:humble-verbs",
    "slug": "humble-verbs",
    "category": "politeness",
    "list_name": "voice-and-politeness",
    "expression": "谦让语动词",
    "connection": "特殊谦让动词（参る、申す、拝見する等）；或 お／ご + 动词连用形 + する／いたす",
    "explanation_zh": "压低自己或己方与对方相关的动作，从而向对方表达敬意。",
    "source_url": "https://guidetojapanese.org/learn/grammar/honorific",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 65,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "私が会場までご案内いたします。",
        "zh": "由我带您到会场。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "不要把顾客或上级的动作说成谦让语；例如询问对方是否看过资料，应使用「ご覧になりましたか」，而非「拝見しましたか」。"
    ],
    "related_entries": [
      "grammar:tae-kim:honorific-verbs",
      "grammar:tae-kim:polite-masu"
    ]
  },
  {
    "id": "grammar:tae-kim:te-shimau",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:te-shimau",
    "slug": "te-shimau",
    "category": "aspect",
    "list_name": "speaker-perspective",
    "expression": "～てしまう",
    "connection": "动词て形 + しまう；口语中「～てしまう／～でしまう」常缩为「～ちゃう／～じゃう」",
    "explanation_zh": "表示动作彻底完成，或带出意外、遗憾等说话人态度；两种含义由语境区分。",
    "source_url": "https://guidetojapanese.org/learn/grammar/unintended",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 66,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "財布を電車に忘れてしまいました。",
        "zh": "我不小心把钱包忘在电车上了。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「～てしまう」不一定都表示后悔；在「宿題を全部やってしまう」中也可只强调全部完成，不能脱离语境固定翻译成“不小心”。"
    ],
    "related_entries": [
      "grammar:tae-kim:te-form",
      "grammar:tae-kim:tsumori"
    ]
  },
  {
    "id": "grammar:tae-kim:generic-koto",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:generic-koto",
    "slug": "generic-koto",
    "category": "nominalization",
    "list_name": "generic-nouns-and-judgment",
    "expression": "こと",
    "connection": "动词或完整小句的普通形 + こと；再按名词接は、が、を等助词",
    "explanation_zh": "把动作、状态或整件事情名词化，便于把它当作话题、主语或宾语。",
    "source_url": "https://guidetojapanese.org/learn/grammar/genericnouns",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 67,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "日本語を毎日読むことは大切です。",
        "zh": "每天阅读日语很重要。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "名词化后的「こと」仍是名词成分，后面需要合适的助词；不要写成缺少主题标记的「読むこと大切だ」。"
    ],
    "related_entries": [
      "grammar:tae-kim:relative-clauses",
      "grammar:tae-kim:ta-koto-ga-aru"
    ]
  },
  {
    "id": "grammar:tae-kim:generic-mono",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:generic-mono",
    "slug": "generic-mono",
    "category": "nominalization",
    "list_name": "generic-nouns-and-judgment",
    "expression": "もの／もん",
    "connection": "动词／い形容词普通形 + もの；名词 + のもの；な形容词 + なもの；句末说明理由时用普通形 + もの／もん",
    "explanation_zh": "「もの」可泛指有形事物，也可在句末带出带感情色彩的解释或辩解；「もん」更口语。",
    "source_url": "https://guidetojapanese.org/learn/grammar/genericnouns",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 68,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "大切なものは、この箱に入れてください。",
        "zh": "请把重要的东西放进这个盒子。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "泛指具体物品通常用「もの」，抽象动作或事情通常用「こと」；句末「だって忙しかったんだもん」又是带情绪的解释，不能与普通物品名词混为一谈。"
    ],
    "related_entries": [
      "grammar:tae-kim:generic-koto",
      "grammar:tae-kim:explanatory-no-da"
    ]
  },
  {
    "id": "grammar:tae-kim:wake-explanation",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:wake-explanation",
    "slug": "wake-explanation",
    "category": "reasoning",
    "list_name": "generic-nouns-and-judgment",
    "expression": "～わけだ／～わけがない",
    "connection": "普通形 + わけ；名词／な形容词 + なわけ；后接だ、ではない、がない等",
    "explanation_zh": "根据已知信息归纳出合乎逻辑的结论；否定为「わけがない」时表示“不可能有这种道理”。",
    "source_url": "https://guidetojapanese.org/learn/grammar/reasoning",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 69,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "毎日練習したから、上手になったわけですね。",
        "zh": "原来是因为每天练习，所以才变熟练了。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「わけだ」是从线索推出结论，不只是补充背景的「のだ」；「わけではない」表示“不见得／并非”，也不同于强烈断定不可能的「わけがない」。"
    ],
    "related_entries": [
      "grammar:tae-kim:explanatory-no-da",
      "grammar:tae-kim:generic-koto"
    ]
  },
  {
    "id": "grammar:tae-kim:hazu-expectation",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:hazu-expectation",
    "slug": "hazu-expectation",
    "category": "modality",
    "list_name": "generic-nouns-and-judgment",
    "expression": "～はずだ",
    "connection": "动词／い形容词普通形 + はず；な形容词 + なはず；名词 + のはず",
    "explanation_zh": "基于计划、事实或推理表达有根据的预期，相当于“按理应该会／应该是”。",
    "source_url": "https://guidetojapanese.org/learn/grammar/should",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 70,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "電車はもう駅に着いているはずです。",
        "zh": "电车按理已经到站了。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「はず」说的是有依据的预期，不是对人的义务要求；“应该遵守约定”要用「べき」，不能用「はず」代替。"
    ],
    "related_entries": [
      "grammar:tae-kim:beki-should",
      "grammar:tae-kim:to-omou"
    ]
  },
  {
    "id": "grammar:tae-kim:beki-should",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:beki-should",
    "slug": "beki-should",
    "category": "modality",
    "list_name": "generic-nouns-and-judgment",
    "expression": "～べきだ／～べきではない",
    "connection": "动词辞书形 + べきだ；する可用「するべき／すべき」；否定判断用「べきではない」",
    "explanation_zh": "表达在道德、规则或情势上应当采取的行动，语气通常比一般建议强。",
    "source_url": "https://guidetojapanese.org/learn/grammar/should",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 71,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "約束は守るべきです。",
        "zh": "约定是应当遵守的。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「べき」不是中性的未来预测，也不适合随意命令对方；过去的“本来应该做”说「するべきだった」，前面的动词仍用辞书形。"
    ],
    "related_entries": [
      "grammar:tae-kim:hazu-expectation",
      "grammar:tae-kim:nakereba-naranai"
    ]
  },
  {
    "id": "grammar:tae-kim:you-similarity",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:you-similarity",
    "slug": "you-similarity",
    "category": "evidentiality",
    "list_name": "similarity-and-evidence",
    "expression": "～ようだ",
    "connection": "动词／い形容词普通形 + ようだ；名词 + のようだ；な形容词 + なようだ",
    "explanation_zh": "依据观察或线索作较中性、较正式的推断，也可用「ような／ように」表达相似的性质或方式。",
    "source_url": "https://guidetojapanese.org/learn/grammar/similarity",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 72,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "道が濡れています。夜に雨が降ったようです。",
        "zh": "路面湿了，看来夜里下过雨。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "名词接「のよう」、な形容词接「なよう」，不能都直接接；仅凭眼前外观说“看起来好吃”时用「おいしそう」，不是「おいしいようだ」。"
    ],
    "related_entries": [
      "grammar:tae-kim:mitai-similarity",
      "grammar:tae-kim:rashii-similarity"
    ]
  },
  {
    "id": "grammar:tae-kim:mitai-similarity",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:mitai-similarity",
    "slug": "mitai-similarity",
    "category": "evidentiality",
    "list_name": "similarity-and-evidence",
    "expression": "～みたいだ",
    "connection": "名词、动词或形容词的普通形 + みたいだ；修饰名词用「みたいな」，修饰动作方式用「みたいに」",
    "explanation_zh": "口语中表达“像……一样”或根据所见作推测，语体比「ようだ」随意。",
    "source_url": "https://guidetojapanese.org/learn/grammar/similarity",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 73,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "あの雲は動物みたいに見えます。",
        "zh": "那朵云看起来像动物。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「みたい」按名词／な形容词方式变化，应说「みたいじゃない」；不要把它当成い形容词写成「みたくない」，也别与「見たい」混淆。"
    ],
    "related_entries": [
      "grammar:tae-kim:you-similarity",
      "grammar:tae-kim:rashii-similarity"
    ]
  },
  {
    "id": "grammar:tae-kim:rashii-similarity",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:rashii-similarity",
    "slug": "rashii-similarity",
    "category": "evidentiality",
    "list_name": "similarity-and-evidence",
    "expression": "～らしい",
    "connection": "名词、动词或形容词的普通形 + らしい；整体按い形容词变化",
    "explanation_zh": "根据听到的信息或间接迹象判断情况；接名词时也可表示符合该类事物的典型特征。",
    "source_url": "https://guidetojapanese.org/learn/grammar/similarity",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 74,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "天気予報では、週末は雪らしいです。",
        "zh": "据天气预报说，周末好像会下雪。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "「雪らしい」是基于间接信息的判断，而「雪のようだ／雪みたいだ」更侧重观察到的相似或推断；「子供らしい」还可能表示“像个孩子”。"
    ],
    "related_entries": [
      "grammar:tae-kim:you-similarity",
