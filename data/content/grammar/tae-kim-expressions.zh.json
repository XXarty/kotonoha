    ]
  },
  {
    "id": "grammar:tae-kim:sou-hearsay",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:sou-hearsay",
    "slug": "sou-hearsay",
    "category": "evidentiality",
    "list_name": "similarity-and-evidence",
    "expression": "～そうだ（传闻）",
    "connection": "完整普通形 + そうだ；名词／な形容词 + だそうだ",
    "explanation_zh": "转述从他人、新闻或其他来源听到的信息，不表示说话人亲眼观察。",
    "source_url": "https://guidetojapanese.org/learn/grammar/similarity",
