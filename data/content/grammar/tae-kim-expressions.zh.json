    "slug": "made-ni-deadline",
    "category": "time",
    "list_name": "time-and-deadlines",
    "expression": "～までに",
    "connection": "截止时间或事件 + までに + 一次性完成的动作",
    "explanation_zh": "设置最迟完成期限，表示动作必须在该界限到来以前完成。",
