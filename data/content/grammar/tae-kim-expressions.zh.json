    ]
  },
  {
    "id": "grammar:tae-kim:sou-appearance",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:sou-appearance",
    "slug": "sou-appearance",
    "category": "evidentiality",
    "list_name": "similarity-and-evidence",
    "expression": "～そうだ（样态）",
    "connection": "动词连用形 + そうだ；い形容词去い + そうだ；な形容词 + そうだ；否定的「ない」常变为「なさそう」",
    "explanation_zh": "根据眼前样态判断某事似乎即将发生，或某性质看起来成立。",
    "source_url": "https://guidetojapanese.org/learn/grammar/similarity",
    "license_key": "cc-by-nc-sa-3.0",
    "content_version": "2026-07-15",
    "display_order": 75,
    "published": true,
    "path": "expressions",
    "examples": [
      {
        "ja": "このケーキはおいしそうです。",
        "zh": "这个蛋糕看起来很好吃。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "样态「そう」不用完整普通形：应说「降りそう／おいしそう」，而传闻才说「降るそうだ／おいしいそうだ」；另外「いい」要变为「よさそう」。"
    ],
    "related_entries": [
      "grammar:tae-kim:sou-hearsay",
