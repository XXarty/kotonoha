    ]
  },
  {
    "id": "grammar:tae-kim:counters",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:counters",
    "slug": "counters",
    "category": "numbers",
    "list_name": "numbers-and-counters",
    "expression": "数字 + 助数词",
    "connection": "数字 + 个体类别对应的助数词（人、本、枚、冊、匹、回等）",
    "explanation_zh": "计算人、物或次数时，要按对象类别选择助数词，并掌握组合后的读音变化。",
    "source_url": "https://guidetojapanese.org/numbers.html",
    "license_key": "cc-by-sa-3.0",
    "content_version": "2026-07-14",
    "display_order": 57,
    "published": true,
    "path": "core",
    "examples": [
      {
        "ja": "コーヒーを二杯ください。",
        "zh": "请给我两杯咖啡。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "助数词不能只按字面拼读；例如「一杯」读「いっぱい」、「三杯」读「さんばい」，要连同音变一起记。"
    ],
    "related_entries": [
      "grammar:tae-kim:kudasai-request",
      "grammar:tae-kim:ka-question"
    ]
  },
  {
    "id": "grammar:tae-kim:relative-clauses",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:relative-clauses",
    "slug": "relative-clauses",
    "category": "clauses",
    "list_name": "noun-modifying-clauses",
    "expression": "修饰小句 + 名词",
    "connection": "动词／い形容词的普通形 + 名词；な形容词词干 + な + 名词；名词 + の + 名词（属性／类别）或名词／な形容词 + である + 名词（判断性修饰）",
    "explanation_zh": "动词、い形容词以及名词／な形容词的过去或否定普通形可直接放在名词前修饰。关键例外是名词和な形容词的非过去肯定形不能带陈述的「だ」：な形容词用「な」，名词间的属性或类别关系常用「の」；需要明确表达判断且文体较正式时可用「である」。",
    "source_url": "https://www.guidetojapanese.org/completeguide.html",
    "license_key": "cc-by-sa-3.0",
    "content_version": "2026-07-14",
    "display_order": 58,
    "published": true,
    "path": "core",
    "examples": [
      {
        "ja": "昨日買った本は机の上にあります。",
        "zh": "昨天买的书在桌子上。",
        "source": "kotonoha-original"
      },
      {
        "ja": "静かな町に住む人を訪ねました。",
        "zh": "我拜访了住在安静小镇的人。",
        "source": "kotonoha-original"
      },
      {
        "ja": "学生である人だけが応募できます。",
        "zh": "只有是学生的人可以报名。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "不要写「静かだ町」或「学生だ人」；非过去肯定时，な形容词应说「静かな町」，名词关系可说「学生の生活」，判断性修饰可说「学生である人」。「だ」不能直接放在被修饰名词前。"
    ],
    "related_entries": [
      "grammar:tae-kim:te-combinations",
      "grammar:tae-kim:transitive-intransitive"
    ]
  },
  {
    "id": "grammar:tae-kim:transitive-intransitive",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:transitive-intransitive",
    "slug": "transitive-intransitive",
    "category": "verbs",
    "list_name": "verb-valency",
    "expression": "他动词／自动词",
    "connection": "他动词：动作对象 + を；自动词：发生变化的事物 + が",
    "explanation_zh": "他动词描述施事者对对象采取动作，自动词描述事物自身发生或呈现变化。",
    "source_url": "https://www.guidetojapanese.org/completeguide.html",
    "license_key": "cc-by-sa-3.0",
    "content_version": "2026-07-14",
    "display_order": 59,
    "published": true,
    "path": "core",
    "examples": [
      {
        "ja": "窓が開いたので、私が閉めました。",
        "zh": "窗户开了，所以我把它关上了。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "要连同助词记动词配对：「窓を開ける」是把窗打开，「窓が開く」是窗户打开，不能互换「を／が」。"
    ],
    "related_entries": [
      "grammar:tae-kim:wo-object",
      "grammar:tae-kim:ga-subject"
    ]
  },
  {
    "id": "grammar:tae-kim:explanatory-no-da",
    "source_id": "tae-kim-grammar",
    "source_key": "tae-kim:explanatory-no-da",
    "slug": "explanatory-no-da",
    "category": "explanation",
    "list_name": "explanatory-tone",
    "expression": "～のだ／～んです",
    "connection": "普通形 + のだ；名词／な形容词 + なのだ（口语常缩为んだ／んです）",
    "explanation_zh": "把前面的内容作为背景、理由或解释提出，也常用于询问对方说明情况。",
    "source_url": "https://www.guidetojapanese.org/completeguide.html",
    "license_key": "cc-by-sa-3.0",
    "content_version": "2026-07-14",
    "display_order": 60,
    "published": true,
    "path": "core",
    "examples": [
      {
        "ja": "電車が遅れたんです。",
        "zh": "电车晚点了（带说明语气）。",
        "source": "kotonoha-original"
      }
    ],
    "common_mistakes": [
      "名词和な形容词的非过去肯定形前要加「な」；应说「学生なんです」，不能说「学生んです」。"
    ],
    "related_entries": [
      "grammar:tae-kim:kara-reason",
